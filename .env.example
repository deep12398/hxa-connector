# HXA connector configuration — copy to .hxa-native.env on each machine.
# Secrets are per-machine and MUST NOT be committed.

HXA_URL=https://conai.cosark.com.cn
HXA_TOKEN=                 # per-machine bot token (REQUIRED, secret)
HXA_ORG_ID=               # org id this bot connects to
HXA_NAME=                 # this bot's HXA name, e.g. longlong

# Watchdog (optional)
HXA_WATCHDOG_APP=hxa-connector
HXA_WATCHDOG_INTERVAL_MS=60000
HXA_WATCHDOG_ALERT_CHANNEL=feishu
HXA_WATCHDOG_ALERT_ENDPOINT=     # set to a C4 endpoint to receive down-alerts
HXA_WATCHDOG_ALERT_AFTER_FAILURES=2

# Deployment root (defaults to /home/ubuntu/zylos)
ZYLOS_DIR=/home/ubuntu/zylos
